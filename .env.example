APP_NAME=AG Directory Manager
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080
APP_DEMO_MODE=true
APP_JWT_SECRET=change-me
APP_JWT_ACCESS_TTL=15m
APP_JWT_REFRESH_TTL=720h
APP_RATE_LIMIT_RPS=5
APP_RATE_LIMIT_BURST=20
APP_SQLITE_PATH=./data/agdm.db
APP_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

LDAP_URL=ldap://127.0.0.1:389
LDAP_BASE_DN=DC=dominio,DC=local
LDAP_BIND_DN=CN=svc-agdm,OU=Service,DC=dominio,DC=local
LDAP_BIND_PASSWORD=change-me
LDAP_START_TLS=false
LDAP_INSECURE_SKIP_VERIFY=true
